<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Luxe Cosmetics Yaoundé – Balea & Denkmit</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
  :root {
    --noir: #0A0A0A;
    --or: #C9A84C;
    --or-clair: #E8C97A;
    --or-pale: #F5E9C8;
    --blanc: #FAFAF8;
    --gris: #6B6B6B;
    --gris-clair: #F2F2EF;
    --radius: 20px;
  }

  * { margin:0; padding:0; box-sizing:border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--blanc);
    color: var(--noir);
    overflow-x: hidden;
  }

  /* ── TOPBAR ── */
  .topbar {
    background: var(--noir);
    color: var(--or);
    text-align: center;
    padding: 10px 20px;
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-weight: 500;
    position: sticky;
    top: 0;
    z-index: 1000;
  }

  .topbar span { opacity: .6; margin: 0 16px; }

  /* ── HEADER ── */
  header {
    background: rgba(250,250,248,0.96);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(201,168,76,0.2);
    position: sticky;
    top: 41px;
    z-index: 999;
    padding: 0 40px;
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 80px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
  }

  .logo-icon {
    width: 44px;
    height: 44px;
    background: var(--noir);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
  }

  .logo-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: 24px;
    font-weight: 700;
    color: var(--noir);
    letter-spacing: 1px;
  }

  .logo-text span { color: var(--or); }

  nav { display: flex; gap: 36px; }

  nav a {
    text-decoration: none;
    color: var(--gris);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: .5px;
    transition: color .2s;
  }

  nav a:hover { color: var(--noir); }

  .header-actions { display: flex; gap: 12px; align-items: center; }

  .btn-cart {
    background: var(--noir);
    color: var(--blanc);
    border: none;
    padding: 10px 20px;
    border-radius: 50px;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: background .2s, transform .2s;
    position: relative;
    font-family: 'DM Sans', sans-serif;
  }

  .btn-cart:hover { background: var(--or); transform: scale(1.03); }

  .cart-badge {
    background: var(--or);
    color: var(--noir);
    font-size: 11px;
    font-weight: 700;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    display: none;
  }

  .btn-admin {
    background: transparent;
    border: 1px solid rgba(201,168,76,0.4);
    color: var(--gris);
    padding: 9px 14px;
    border-radius: 50px;
    font-size: 13px;
    cursor: pointer;
    transition: all .2s;
    font-family: 'DM Sans', sans-serif;
  }

  .btn-admin:hover { border-color: var(--or); color: var(--or); }

  /* ── HERO ── */
  .hero {
    min-height: 92vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 40px;
    gap: 80px;
  }

  .hero-text { }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--or-pale);
    color: #8B6914;
    padding: 8px 18px;
    border-radius: 50px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 28px;
  }

  .hero h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(52px, 6vw, 82px);
    line-height: 1.05;
    font-weight: 700;
    margin-bottom: 24px;
    color: var(--noir);
  }

  .hero h1 em {
    font-style: italic;
    color: var(--or);
    display: block;
  }

  .hero-desc {
    font-size: 17px;
    color: var(--gris);
    line-height: 1.7;
    max-width: 480px;
    margin-bottom: 40px;
  }

  .hero-cta { display: flex; gap: 16px; flex-wrap: wrap; }

  .btn-primary {
    background: var(--noir);
    color: var(--blanc);
    padding: 16px 36px;
    border-radius: 50px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition: all .3s;
    border: 2px solid var(--noir);
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
  }

  .btn-primary:hover { background: var(--or); border-color: var(--or); color: var(--noir); transform: translateY(-2px); box-shadow: 0 12px 40px rgba(201,168,76,0.4); }

  .btn-secondary {
    background: transparent;
    color: var(--noir);
    padding: 16px 36px;
    border-radius: 50px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition: all .3s;
    border: 2px solid rgba(0,0,0,0.15);
  }

  .btn-secondary:hover { border-color: var(--noir); transform: translateY(-2px); }

  .hero-stats {
    display: flex;
    gap: 40px;
    margin-top: 56px;
    padding-top: 40px;
    border-top: 1px solid rgba(0,0,0,0.08);
  }

  .stat-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 38px;
    font-weight: 700;
    color: var(--nor);
    line-height: 1;
  }

  .stat-num span { color: var(--or); }

  .stat-label { font-size: 12px; color: var(--gris); text-transform: uppercase; letter-spacing: 1px; margin-top: 4px; }

  .hero-visual {
    position: relative;
    height: 600px;
  }

  .hero-img-main {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 32px;
    box-shadow: 0 40px 100px rgba(0,0,0,0.15);
  }

  .hero-card-float {
    position: absolute;
    background: white;
    border-radius: 20px;
    padding: 16px 20px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.12);
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .hero-card-float.card-1 { bottom: 40px; left: -30px; }
  .hero-card-float.card-2 { top: 40px; right: -20px; }

  .card-float-icon { font-size: 28px; }

  .card-float-text strong { display: block; font-size: 15px; font-weight: 700; }
  .card-float-text small { color: var(--gris); font-size: 12px; }

  /* ── SECTION TITRE ── */
  .section-header { text-align: center; margin-bottom: 64px; }
  .section-label { display: inline-block; font-size: 11px; font-weight: 600; letter-spacing: 3px; text-transform: uppercase; color: var(--or); margin-bottom: 16px; }
  .section-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(36px, 4vw, 56px); font-weight: 700; line-height: 1.1; }

  /* ── PRODUCTS ── */
  #products { padding: 100px 40px; max-width: 1200px; margin: 0 auto; }

  .filters { display: flex; gap: 10px; margin-bottom: 48px; flex-wrap: wrap; justify-content: center; }

  .filter-btn {
    padding: 10px 24px;
    border-radius: 50px;
    border: 1.5px solid rgba(0,0,0,0.12);
    background: transparent;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: all .25s;
    font-family: 'DM Sans', sans-serif;
    color: var(--gris);
  }

  .filter-btn.active, .filter-btn:hover { background: var(--noir); color: white; border-color: var(--noir); }

  .products-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 32px; }

  /* ── PRODUCT CARD ── */
  .product-card {
    background: white;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid rgba(0,0,0,0.07);
    transition: transform .35s, box-shadow .35s;
    cursor: pointer;
    position: relative;
  }

  .product-card:hover { transform: translateY(-8px); box-shadow: 0 30px 80px rgba(0,0,0,0.12); }

  .product-img-wrap {
    position: relative;
    height: 280px;
    overflow: hidden;
    background: var(--gris-clair);
  }

  .product-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .6s;
  }

  .product-card:hover .product-img-wrap img { transform: scale(1.06); }

  .product-badge {
    position: absolute;
    top: 16px;
    left: 16px;
    padding: 6px 14px;
    border-radius: 50px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .5px;
    text-transform: uppercase;
  }

  .badge-hot { background: var(--noir); color: var(--or); }
  .badge-new { background: #1A5C38; color: white; }
  .badge-limited { background: #8B2500; color: white; }

  .stock-low {
    position: absolute;
    top: 16px;
    right: 16px;
    background: rgba(255,255,255,0.95);
    color: #C0392B;
    font-size: 11px;
    font-weight: 700;
    padding: 6px 12px;
    border-radius: 50px;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .product-heart {
    position: absolute;
    bottom: 16px;
    right: 16px;
    width: 36px;
    height: 36px;
    background: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    border: none;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(0,0,0,.1);
    transition: transform .2s;
  }

  .product-heart:hover { transform: scale(1.15); }

  .product-body { padding: 24px; }

  .product-cat { font-size: 11px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--or); margin-bottom: 8px; }

  .product-name { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 700; line-height: 1.2; margin-bottom: 10px; color: var(--noir); }

  .product-desc { font-size: 13px; color: var(--gris); line-height: 1.6; margin-bottom: 16px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

  .product-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 20px; }

  .product-tag { font-size: 11px; background: var(--gris-clair); color: var(--gris); padding: 5px 12px; border-radius: 50px; font-weight: 500; }

  .product-footer { display: flex; align-items: center; justify-content: space-between; }

  .product-price { }
  .price-current { font-family: 'Cormorant Garamond', serif; font-size: 28px; font-weight: 700; color: var(--noir); }
  .price-unit { font-size: 13px; color: var(--gris); margin-left: 2px; }
  .price-old { font-size: 13px; color: var(--gris); text-decoration: line-through; display: block; }
  .price-discount { display: inline-block; background: #FEE2E2; color: #C0392B; font-size: 11px; font-weight: 700; padding: 3px 8px; border-radius: 4px; margin-left: 6px; }

  .product-actions { display: flex; gap: 8px; }

  .btn-wa {
    background: #25D366;
    color: white;
    border: none;
    padding: 12px 18px;
    border-radius: 50px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: all .2s;
    font-family: 'DM Sans', sans-serif;
    white-space: nowrap;
  }

  .btn-wa:hover { background: #1EBD5B; transform: scale(1.03); box-shadow: 0 8px 24px rgba(37,211,102,0.35); }

  .btn-add {
    background: var(--gris-clair);
    color: var(--noir);
    border: none;
    width: 46px;
    height: 46px;
    border-radius: 50px;
    font-size: 20px;
    cursor: pointer;
    transition: all .2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .btn-add:hover { background: var(--noir); color: white; }

  /* ── WHY US ── */
  .why-section { background: var(--noir); color: white; padding: 100px 40px; }
  .why-inner { max-width: 1200px; margin: 0 auto; }
  .why-section .section-title { color: white; }
  .why-section .section-label { color: var(--or); }

  .why-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; margin-top: 64px; }

  .why-card {
    border: 1px solid rgba(201,168,76,0.2);
    border-radius: var(--radius);
    padding: 36px;
    transition: border-color .3s, transform .3s;
  }

  .why-card:hover { border-color: var(--or); transform: translateY(-4px); }

  .why-icon { font-size: 36px; margin-bottom: 20px; }
  .why-title { font-family: 'Cormorant Garamond', serif; font-size: 24px; font-weight: 700; margin-bottom: 12px; color: var(--or-clair); }
  .why-text { font-size: 14px; color: rgba(255,255,255,0.6); line-height: 1.7; }

  /* ── TESTIMONIALS ── */
  .testimonials-section { padding: 100px 40px; max-width: 1200px; margin: 0 auto; }

  .testi-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }

  .testi-card {
    background: var(--gris-clair);
    border-radius: var(--radius);
    padding: 36px;
    position: relative;
    transition: transform .3s, box-shadow .3s;
  }

  .testi-card:hover { transform: translateY(-4px); box-shadow: 0 20px 60px rgba(0,0,0,0.08); }

  .testi-quote { font-size: 48px; color: var(--or); font-family: Georgia, serif; line-height: 1; margin-bottom: 16px; }

  .testi-text { font-size: 15px; color: var(--gris); line-height: 1.7; margin-bottom: 24px; font-style: italic; }

  .testi-stars { color: var(--or); font-size: 16px; margin-bottom: 16px; letter-spacing: 2px; }

  .testi-author { display: flex; align-items: center; gap: 12px; }
  .testi-avatar { width: 44px; height: 44px; background: var(--noir); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--or); font-weight: 700; font-size: 18px; }
  .testi-name { font-weight: 700; font-size: 15px; }
  .testi-loc { font-size: 12px; color: var(--gris); }

  /* ── DELIVERY ── */
  .delivery-section { padding: 60px 40px; background: var(--or-pale); }
  .delivery-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 40px; }

  .delivery-card { background: white; border-radius: var(--radius); padding: 40px; box-shadow: 0 8px 40px rgba(0,0,0,0.06); }
  .delivery-card h3 { font-family: 'Cormorant Garamond', serif; font-size: 28px; font-weight: 700; margin-bottom: 24px; }
  .delivery-item { display: flex; gap: 14px; margin-bottom: 20px; align-items: flex-start; }
  .delivery-item-icon { font-size: 22px; margin-top: 2px; }
  .delivery-item-text strong { display: block; font-weight: 700; margin-bottom: 2px; }
  .delivery-item-text small { color: var(--gris); font-size: 13px; }

  .pay-badge { display: flex; align-items: center; justify-content: space-between; background: var(--gris-clair); padding: 14px 20px; border-radius: 12px; margin-bottom: 10px; font-weight: 600; font-size: 14px; }
  .pay-badge span { font-size: 20px; }

  /* ── CONTACT ── */
  .contact-section { padding: 100px 40px; max-width: 1200px; margin: 0 auto; text-align: center; }
  .contact-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; max-width: 800px; margin: 48px auto 0; }

  .contact-card {
    padding: 36px 24px;
    border-radius: var(--radius);
    text-decoration: none;
    color: white;
    transition: transform .3s, box-shadow .3s;
    display: block;
  }

  .contact-card:hover { transform: translateY(-6px); box-shadow: 0 20px 60px rgba(0,0,0,0.2); }
  .contact-card.green { background: #128C7E; }
  .contact-card.blue { background: #0088CC; }
  .contact-card.gold { background: var(--or); color: var(--noir); }

  .contact-card-icon { font-size: 36px; margin-bottom: 12px; }
  .contact-card-name { font-weight: 700; font-size: 16px; margin-bottom: 4px; }
  .contact-card-val { font-size: 13px; opacity: .85; }

  /* ── FOOTER ── */
  footer { background: var(--noir); color: rgba(255,255,255,0.5); padding: 48px 40px; text-align: center; }
  footer .footer-logo { font-family: 'Cormorant Garamond', serif; font-size: 28px; color: var(--or); font-weight: 700; margin-bottom: 8px; }
  footer p { font-size: 13px; margin-top: 24px; }

  /* ── FLOATING WA ── */
  .wa-float {
    position: fixed;
    bottom: 30px;
    right: 30px;
    z-index: 999;
    width: 60px;
    height: 60px;
    background: #25D366;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    box-shadow: 0 8px 30px rgba(37,211,102,0.5);
    text-decoration: none;
    transition: transform .3s, box-shadow .3s;
    animation: pulse-wa 2s infinite;
  }

  .wa-float:hover { transform: scale(1.1); box-shadow: 0 16px 50px rgba(37,211,102,0.6); }

  @keyframes pulse-wa {
    0%,100% { box-shadow: 0 8px 30px rgba(37,211,102,0.5); }
    50% { box-shadow: 0 8px 50px rgba(37,211,102,0.8); }
  }

  /* ── CART PANEL ── */
  .cart-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    backdrop-filter: blur(4px);
    z-index: 2000;
  }

  .cart-panel {
    position: fixed;
    right: 0; top: 0; bottom: 0;
    width: 420px;
    max-width: 100vw;
    background: white;
    z-index: 2001;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform .35s cubic-bezier(0.4,0,0.2,1);
    border-left: 1px solid rgba(0,0,0,0.08);
  }

  .cart-panel.open { transform: translateX(0); }
  .cart-overlay.open { display: block; }

  .cart-header { padding: 24px 28px; border-bottom: 1px solid rgba(0,0,0,0.08); display: flex; align-items: center; justify-content: space-between; }
  .cart-header h3 { font-family: 'Cormorant Garamond', serif; font-size: 24px; font-weight: 700; }
  .cart-close { background: none; border: none; font-size: 22px; cursor: pointer; color: var(--gris); transition: color .2s; }
  .cart-close:hover { color: var(--noir); }

  .cart-body { flex: 1; overflow-y: auto; padding: 20px 28px; }

  .cart-empty { text-align: center; padding: 80px 0; color: var(--gris); }
  .cart-empty-icon { font-size: 56px; margin-bottom: 16px; }
  .cart-empty p { font-size: 16px; }

  .cart-item { display: flex; gap: 16px; padding: 16px 0; border-bottom: 1px solid rgba(0,0,0,0.06); }
  .cart-item-img { width: 80px; height: 80px; object-fit: cover; border-radius: 12px; }
  .cart-item-info { flex: 1; }
  .cart-item-name { font-weight: 700; font-size: 14px; margin-bottom: 4px; }
  .cart-item-price { color: var(--gris); font-size: 13px; margin-bottom: 10px; }
  .cart-qty { display: flex; align-items: center; gap: 12px; }
  .qty-btn { width: 28px; height: 28px; border: 1.5px solid rgba(0,0,0,0.15); border-radius: 50%; background: none; cursor: pointer; font-size: 16px; display: flex; align-items: center; justify-content: center; transition: all .2s; font-weight: 700; }
  .qty-btn:hover { background: var(--noir); color: white; border-color: var(--noir); }
  .qty-num { font-weight: 700; font-size: 15px; min-width: 20px; text-align: center; }
  .cart-item-remove { background: none; border: none; color: var(--gris); font-size: 20px; cursor: pointer; align-self: flex-start; transition: color .2s; }
  .cart-item-remove:hover { color: #C0392B; }
  .cart-item-total { font-weight: 700; font-size: 15px; text-align: right; align-self: center; white-space: nowrap; }

  .cart-footer { padding: 20px 28px; border-top: 1px solid rgba(0,0,0,0.08); background: var(--gris-clair); }
  .cart-line { display: flex; justify-content: space-between; font-size: 14px; margin-bottom: 8px; }
  .cart-total-line { display: flex; justify-content: space-between; font-size: 20px; font-weight: 800; padding-top: 12px; border-top: 2px solid rgba(0,0,0,0.1); margin-top: 8px; margin-bottom: 16px; }
  .cart-discount { color: #1A5C38; font-weight: 600; }

  .btn-order {
    width: 100%;
    background: #25D366;
    color: white;
    border: none;
    padding: 18px;
    border-radius: 14px;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    transition: all .3s;
    font-family: 'DM Sans', sans-serif;
  }

  .btn-order:hover { background: #1EBD5B; transform: translateY(-2px); box-shadow: 0 12px 40px rgba(37,211,102,0.4); }

  /* ── ADMIN MODAL ── */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
