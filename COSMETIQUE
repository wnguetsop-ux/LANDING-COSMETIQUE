}

function save() {
  localStorage.setItem('lc_products', JSON.stringify(products));
  localStorage.setItem('lc_cart', JSON.stringify(cart));
}

// ── RENDER ──
function render() {
  renderFilters();
  renderProducts();
  renderCart();
}

let activeFilter = 'Tous';

function renderFilters() {
  const cats = ['Tous', ...new Set(products.map(p => p.category))];
  document.getElementById('filters').innerHTML = cats.map(c =>
    `<button class="filter-btn ${c===activeFilter?'active':''}" onclick="setFilter('${c}')">${c}</button>`
  ).join('');
}

function setFilter(cat) { activeFilter = cat; render(); }

function renderProducts() {
  const filtered = activeFilter === 'Tous' ? products : products.filter(p => p.category === activeFilter);
  document.getElementById('products-grid').innerHTML = filtered.map(p => {
    const disc = p.oldPrice ? Math.round((1 - p.price/p.oldPrice)*100) : 0;
    const badge = p.badge === 'hot' ? `<span class="product-badge badge-hot">🔥 Populaire</span>` :
                  p.badge === 'new' ? `<span class="product-badge badge-new">✨ Nouveau</span>` :
                  p.badge === 'limited' ? `<span class="product-badge badge-limited">⚡ Limité</span>` : '';
    const stockAlert = p.stock <= 5 ? `<span class="stock-low">⚠ ${p.stock} restants</span>` : '';
    const tags = (p.benefits||[]).slice(0,2).map(b=>`<span class="product-tag">${b}</span>`).join('');
    const img = (p.images && p.images[0]) ? p.images[0] : 'https://images.unsplash.com/photo-1556228720-195a672e8a03?w=600&h=600&fit=crop';
    return `
      <div class="product-card">
        <div class="product-img-wrap">
          ${badge}${stockAlert}
          <img src="${img}" alt="${p.name}" loading="lazy"/>
          <button class="product-heart" onclick="event.stopPropagation()" data-liked="false" onclick="this.textContent=this.dataset.liked==='false'?'❤️':'🤍';this.dataset.liked=this.dataset.liked==='false'?'true':'false'">🤍</button>
        </div>
        <div class="product-body">
          <div class="product-cat">${p.category}</div>
          <div class="product-name">${p.name}</div>
          <div class="product-desc">${p.description}</div>
          <div class="product-tags">${tags}</div>
          <div class="product-footer">
            <div class="product-price">
              ${p.oldPrice ? `<span class="price-old">${p.oldPrice.toLocaleString()} FCFA</span>` : ''}
              <span class="price-current">${p.price.toLocaleString()}</span><span class="price-unit"> FCFA</span>
              ${disc ? `<span class="price-discount">-${disc}%</span>` : ''}
            </div>
            <div class="product-actions">
              <button class="btn-wa" onclick="orderWA(${p.id})">💬 Commander</button>
              <button class="btn-add" onclick="addToCart(${p.id})" title="Ajouter au panier">+</button>
            </div>
          </div>
        </div>
      </div>`;
  }).join('');
}

// ── CART ──
function addToCart(id) {
  const p = products.find(x => x.id === id);
  if (!p) return;
  const ex = cart.find(x => x.id === id);
  if (ex) ex.qty++;
  else cart.push({ id, qty: 1 });
  save();
  renderCart();
  openCartPanel();
}

function removeFromCart(id) {
  cart = cart.filter(x => x.id !== id);
  save(); renderCart();
}

function changeQty(id, delta) {
  const ex = cart.find(x => x.id === id);
  if (!ex) return;
  ex.qty = Math.max(1, ex.qty + delta);
  save(); renderCart();
}

function renderCart() {
  const count = cart.reduce((s,x) => s + x.qty, 0);
  const badge = document.getElementById('cart-badge');
  if (count > 0) { badge.style.display='flex'; badge.textContent=count; }
  else badge.style.display='none';

  const body = document.getElementById('cart-body');
  const footer = document.getElementById('cart-footer');

  if (cart.length === 0) {
    body.innerHTML = `<div class="cart-empty"><div class="cart-empty-icon">🛒</div><p>Votre panier est vide</p></div>`;
    footer.style.display = 'none';
    return;
  }

  body.innerHTML = cart.map(item => {
    const p = products.find(x => x.id === item.id);
    if (!p) return '';
    const img = p.images && p.images[0] ? p.images[0] : '';
    return `
      <div class="cart-item">
        <img class="cart-item-img" src="${img}" alt="${p.name}"/>
        <div class="cart-item-info">
          <div class="cart-item-name">${p.name}</div>
          <div class="cart-item-price">${p.price.toLocaleString()} FCFA / unité</div>
          <div class="cart-qty">
            <button class="qty-btn" onclick="changeQty(${p.id},-1)">−</button>
            <span class="qty-num">${item.qty}</span>
            <button class="qty-btn" onclick="changeQty(${p.id},1)">+</button>
          </div>
        </div>
        <button class="cart-item-remove" onclick="removeFromCart(${p.id})">✕</button>
        <div class="cart-item-total">${(p.price*item.qty).toLocaleString()} FCFA</div>
      </div>`;
  }).join('');

  const subtotal = cart.reduce((s,x) => { const p=products.find(q=>q.id===x.id); return s+(p?p.price*x.qty:0); }, 0);
  const hasDisc = count >= 3;
  const disc = hasDisc ? Math.round(subtotal * 0.05) : 0;
  const total = subtotal - disc + 1000;

  document.getElementById('cart-subtotal').textContent = subtotal.toLocaleString() + ' FCFA';
  document.getElementById('cart-total').textContent = total.toLocaleString() + ' FCFA';
  const dl = document.getElementById('cart-discount-line');
  if (hasDisc) { dl.style.display='flex'; document.getElementById('cart-discount').textContent='-'+disc.toLocaleString()+' FCFA'; }
  else dl.style.display='none';
  footer.style.display = 'block';
}

function orderCart() {
  if (cart.length === 0) return;
  const subtotal = cart.reduce((s,x) => { const p=products.find(q=>q.id===x.id); return s+(p?p.price*x.qty:0); }, 0);
  const count = cart.reduce((s,x) => s+x.qty, 0);
  const disc = count >= 3 ? Math.round(subtotal * 0.05) : 0;
  const total = subtotal - disc + 1000;
  const lines = cart.map(x => { const p=products.find(q=>q.id===x.id); return p?`• ${p.name} x${x.qty} = ${(p.price*x.qty).toLocaleString()} FCFA`:''; }).join('\n');
  const msg = `🛒 *COMMANDE LUXE COSMETICS*\n\n${lines}\n\n💰 Sous-total: ${subtotal.toLocaleString()} FCFA${disc?`\n🎁 Remise 5%: -${disc.toLocaleString()} FCFA`:''}\n🚚 Livraison: 1 000 FCFA\n\n✅ *TOTAL: ${total.toLocaleString()} FCFA*\n\nMerci de confirmer ma commande !`;
  window.open(`https://wa.me/${WA}?text=${encodeURIComponent(msg)}`, '_blank');
}

function orderWA(id) {
  const p = products.find(x => x.id === id);
  if (!p) return;
  const msg = `Bonjour ! Je souhaite commander :\n\n*${p.name}*\nPrix : ${p.price.toLocaleString()} FCFA\n\nMerci de confirmer la disponibilité.`;
  window.open(`https://wa.me/${WA}?text=${encodeURIComponent(msg)}`, '_blank');
}

function toggleCart() {
  document.getElementById('cart-panel').classList.toggle('open');
  document.getElementById('cart-overlay').classList.toggle('open');
}

function openCartPanel() {
  document.getElementById('cart-panel').classList.add('open');
  document.getElementById('cart-overlay').classList.add('open');
}

// ── ADMIN ──
function openAdmin() { document.getElementById('admin-modal').classList.add('open'); }
function closeAdmin() { document.getElementById('admin-modal').classList.remove('open'); }

function adminLogin() {
  const pwd = document.getElementById('admin-pwd').value;
  if (pwd === ADMIN_PASS) {
    document.getElementById('admin-login').style.display = 'none';
    document.getElementById('admin-panel').style.display = 'block';
    renderAdminList();
  } else {
    alert('❌ Mot de passe incorrect !');
  }
}

function showTab(tab) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  event.target.classList.add('active');
  document.getElementById('tab-list').style.display = tab === 'list' ? 'block' : 'none';
  document.getElementById('tab-form').style.display = tab === 'form' ? 'block' : 'none';
  if (tab === 'form') resetForm();
}

function renderAdminList() {
  document.getElementById('admin-product-list').innerHTML = products.map(p => `
    <div class="admin-product-item">
      <img class="admin-product-img" src="${p.images&&p.images[0]?p.images[0]:'https://via.placeholder.com/56'}" alt="${p.name}"/>
      <div class="admin-product-info">
        <div class="admin-product-name">${p.name}</div>
        <div class="admin-product-price">${p.price.toLocaleString()} FCFA · Stock: ${p.stock}</div>
      </div>
      <div class="admin-actions">
        <button class="btn-edit" onclick="editProduct(${p.id})">✏ Modifier</button>
        <button class="btn-delete" onclick="deleteProduct(${p.id})">🗑</button>
      </div>
    </div>`).join('');
}

function resetForm() {
  document.getElementById('edit-id').value = '';
  document.getElementById('f-name').value = '';
  document.getElementById('f-cat').value = 'Soins Visage';
  document.getElementById('f-price').value = '';
  document.getElementById('f-oldprice').value = '';
  document.getElementById('f-stock').value = '';
  document.getElementById('f-badge').value = '';
  document.getElementById('f-desc').value = '';
  editImages = [];
  renderImgPreview();
}

function editProduct(id) {
  const p = products.find(x => x.id === id);
  if (!p) return;
  document.getElementById('edit-id').value = id;
  document.getElementById('f-name').value = p.name;
  document.getElementById('f-cat').value = p.category;
  document.getElementById('f-price').value = p.price;
  document.getElementById('f-oldprice').value = p.oldPrice || '';
  document.getElementById('f-stock').value = p.stock;
  document.getElementById('f-badge').value = p.badge || '';
  document.getElementById('f-desc').value = p.description;
  editImages = [...(p.images || [])];
  renderImgPreview();
  showTab('form');
  document.querySelectorAll('.tab-btn')[1].classList.add('active');
  document.querySelectorAll('.tab-btn')[0].classList.remove('active');
}

function deleteProduct(id) {
  if (!confirm('Supprimer ce produit ?')) return;
  products = products.filter(x => x.id !== id);
  save(); render(); renderAdminList();
}

function saveProduct() {
  const name = document.getElementById('f-name').value.trim();
  const desc = document.getElementById('f-desc').value.trim();
  const price = parseInt(document.getElementById('f-price').value);
  if (!name || !desc || !price || editImages.length === 0) {
    alert('⚠ Remplissez tous les champs et ajoutez au moins une image.');
    return;
  }
  const id = parseInt(document.getElementById('edit-id').value) || Date.now();
  const prod = {
    id,
    name,
    category: document.getElementById('f-cat').value,
    price,
    oldPrice: parseInt(document.getElementById('f-oldprice').value) || null,
    stock: parseInt(document.getElementById('f-stock').value) || 0,
    badge: document.getElementById('f-badge').value || null,
    description: desc,
    images: [...editImages],
    benefits: []
  };
  const idx = products.findIndex(x => x.id === id);
  if (idx >= 0) products[idx] = prod;
  else products.push(prod);
  save(); render(); renderAdminList();
  resetForm();
  alert('✅ Produit enregistré !');
}

function addImageURL() {
  const url = document.getElementById('f-img-url').value.trim();
  if (!url) return;
  editImages.push(url);
  document.getElementById('f-img-url').value = '';
  renderImgPreview();
}

function uploadImage(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onloadend = () => { editImages.push(reader.result); renderImgPreview(); };
  reader.readAsDataURL(file);
}

function removeImg(idx) { editImages.splice(idx, 1); renderImgPreview(); }

function renderImgPreview() {
  document.getElementById('img-preview').innerHTML = editImages.map((img,i) =>
    `<div class="img-thumb-wrap">
      <img class="img-thumb" src="${img}" alt=""/>
      <button class="img-remove" onclick="removeImg(${i})">✕</button>
    </div>`).join('');
}

render();
</script>
</body>
</html>
